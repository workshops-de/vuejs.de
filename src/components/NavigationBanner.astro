---
import { siteConfig } from '../config/site';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  href?: string;
  enabled?: boolean;
}

const lang = getLangFromUrl(Astro.url);
const bannerConfig = siteConfig.navigation.banner;

const {
  href = bannerConfig.href,
  enabled = bannerConfig.enabled
} = Astro.props;

const message = bannerConfig.message[lang] ?? bannerConfig.message.de;
---

{enabled && (
  <div class="bg-gradient-to-r from-primary-800 to-accent-700 text-center py-2.5 px-4">
    <a href={href} target="_blank" rel="noopener" class="text-sm font-medium text-white hover:text-white/90 hover:underline">
      <span set:html={message} />
    </a>
  </div>
)}
